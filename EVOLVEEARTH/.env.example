# ── EvolveEarth Soul Signature — environment ──
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env. It contains your wallet's private key.

# The private key of the wallet that deploys + mints.
# Create a fresh H160 (Ethereum-style) wallet in MetaMask and export its key:
# Account Details -> Show private key. Use a throwaway wallet, not your main one.
PRIVATE_KEY=

# Bittensor Subtensor EVM RPC endpoints. The public defaults below work to start.
SUBTENSOR_RPC=https://lite.chain.opentensor.ai
SUBTENSOR_TESTNET_RPC=https://test.chain.opentensor.ai

# Set after you deploy — the mint/preview scripts read this.
SOUL_CONTRACT_ADDRESS=
